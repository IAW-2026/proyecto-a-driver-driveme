generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EstadoConductor {
  OFFLINE
  ONLINE
  OCUPADO
}

enum EstadoViaje {
  ACEPTADO
  EN_CURSO
  FINALIZADO
  CANCELADO_POR_CONDUCTOR
}

enum MetodoPago {
  EFECTIVO
  TARJETA
}

model Conductor {
  id                    String          @id // clerk_user_id
  nombre                String
  apellido              String
  estado                EstadoConductor @default(OFFLINE)
  latitud_actual        Float?
  longitud_actual       Float?
  calificacion_promedio Float           @default(5.0)
  isActive              Boolean         @default(true)
  
  // Relaciones
  vehiculos             Vehiculo[]
  viajes                Viaje[]
}

model Vehiculo {
  id           String    @id @default(uuid())
  id_conductor String
  patente      String    @unique
  marca        String
  modelo       String
  anio         Int
  color        String
  isActive     Boolean   @default(true)

  // Relaciones
  conductor    Conductor @relation(fields: [id_conductor], references: [id])
  viajes       Viaje[]
}

model Viaje {
  id                String      @id @default(uuid()) // id_viaje
  id_solicitud      String      @unique
  id_pasajero       String      
  id_conductor      String
  id_vehiculo       String
  estado_actual     EstadoViaje @default(ACEPTADO)
  tiempo_aceptado   DateTime    @default(now())
  tiempo_comienzo   DateTime?
  tiempo_completado DateTime?
  metodo_pago       MetodoPago
  precio_final      Float

  // Relaciones
  conductor         Conductor   @relation(fields: [id_conductor], references: [id])
  vehiculo          Vehiculo    @relation(fields: [id_vehiculo], references: [id])
}